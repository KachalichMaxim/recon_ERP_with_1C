RECON_API_HOST=0.0.0.0
RECON_API_PORT=8780
RECON_ENV=production
RECON_REQUIRE_ERP_TOKEN=1
RECON_SESSION_SECRET=
RECON_ALLOW_DIRECT_ERP_LOGIN=0
RECON_UI_DEMO=0
RECON_DEV_AUTH=0
RECON_ERP_TOKEN_VALIDATE_URL=
RECON_ERP_TOKEN_VALIDATE_TIMEOUT=10

RECON_ERP_DB_HOST=
RECON_ERP_DB_PORT=3306
RECON_ERP_DB_NAME=
RECON_ERP_DB_USER=
RECON_ERP_DB_PASSWORD=
RECON_ERP_DB_CONNECT_TIMEOUT=5
RECON_ERP_DB_READ_TIMEOUT=30
RECON_ERP_DB_WRITE_TIMEOUT=30
# Optional for local split-tunnel VPN checks, for example ppp0 address 10.54.10.53.
# Leave empty in production; production server must have normal network route to ERP MariaDB.
RECON_ERP_DB_BIND_ADDRESS=

RECON_ONEC_REST_BASE_URL=
RECON_ONEC_REST_TOKEN=
RECON_ONEC_REST_USER=
RECON_ONEC_REST_PASSWORD=
RECON_ONEC_REST_TIMEOUT=60
# Optional for local split-tunnel VPN checks, for example ppp0 address 10.54.10.53.
# Leave empty in production; production server must have normal network route to 1C.
RECON_ONEC_REST_BIND_ADDRESS=
